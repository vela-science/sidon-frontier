# A Vela frontier commits the record, not the derivation.
# Authority: .vela/events/ (signed log). Pins: vela.lock. Read-entry: frontier.json.
# Committed: .vela/, witnesses/, frontier.json, frontier.yaml, vela.lock, bounds.json.

# Regenerated by CI + the hub from the event log — never committed.
proof/

# Producer-local scratch (not replayable truth).
records/                 # vela.activity-record receipts — superseded by signed events
packets/                 # review worklist, rebuilt on demand
activity/                # vac_ candidate stream from harvest runs
/.vela/tasks/            # per-run lease + work-session state
/.vela/workspaces/

# Tooling scratch
__pycache__/
*.pyc
.venv/
.pytest_cache/
.DS_Store

# Vela operational recovery and frontier locks (non-authoritative).
/.vela/operation-journals/
